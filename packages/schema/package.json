{
	"$schema": "https://www.schemastore.org/package.json",
	"author": {
		"email": "hunarroopcodes@gmail.com",
		"name": "Hunar Roop Kahlon"
	},
	"bugs": {
		"url": "https://github.com/sytizen/sytizen/issues"
	},
	"dependencies": {
		"@standard-schema/spec": "catalog:"
	},
	"description": "Standard Schema data declaration, generation, and validation",
	"devDependencies": {
		"@biomejs/biome": "catalog:"
	},
	"exports": {
		"./LICENSE": "./LICENSE",
		"./package.json": "./package.json"
	},
	"files": [
		"./LICENSE",
		"./README.md",
		"./package.json"
	],
	"keywords": [
		"data",
		"declaration",
		"generation",
		"schema",
		"typescript",
		"validation"
	],
	"license": "MIT",
	"name": "@sytizen/schema",
	"peerDependencies": {
		"typescript": "catalog:"
	},
	"repository": {
		"directory": "packages/schema",
		"type": "git",
		"url": "git+https://github.com/sytizen/sytizen.git"
	},
	"scripts": {
		"declarations": "tsc --emitDeclarationOnly",
		"emit": "tsc",
		"fmt": "biome check --write",
		"lint": "biome check",
		"typecheck": "tsc --noEmit"
	},
	"sideEffects": false,
	"type": "module",
	"version": "0.0.0"
}
