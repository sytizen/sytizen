	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@sytizen/configs": "workspace:"
	},
	"engines": {
		"bun": ">=1.3",
		"deno": ">=2.6",
		"node": ">=24.12"
	},
	"exports": {
		"./package.json": "./package.json"
	},
	"packageManager": "bun@1.3.5",
